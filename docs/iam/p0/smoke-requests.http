@host = http://127.0.0.1:8000
@json = application/json
@access_token = REPLACE_WITH_ACCESS_TOKEN
@refresh_token = REPLACE_WITH_REFRESH_TOKEN
@session_id = REPLACE_WITH_SESSION_ID

### 1) Login
POST {{host}}/iam/auth/login
Content-Type: {{json}}

{
  "username": "admin",
  "password": "REPLACE_WITH_PASSWORD_PAYLOAD"
}

### 2) Refresh
POST {{host}}/iam/auth/refresh
Content-Type: {{json}}

{
  "refresh_token": "{{refresh_token}}"
}

### 3) Profile (requires permission iam:auth:profile)
POST {{host}}/iam/auth/profile
Authorization: Bearer {{access_token}}
Content-Type: {{json}}

{}

### 4) Current user (requires permission iam:auth:current_user)
POST {{host}}/iam/auth/current-user
Authorization: Bearer {{access_token}}
Content-Type: {{json}}

{}

### 5) Data scopes (requires permission iam:auth:data_scopes)
POST {{host}}/iam/auth/data-scopes
Authorization: Bearer {{access_token}}
Content-Type: {{json}}

{
  "permission_codes": [
    "iam:department:list",
    "iam:user:list"
  ]
}

### 6) Session list (requires permission iam:session:list)
POST {{host}}/iam/session/list
Authorization: Bearer {{access_token}}
Content-Type: {{json}}

{}

### 7) Session revoke (requires permission iam:session:revoke)
POST {{host}}/iam/session/revoke
Authorization: Bearer {{access_token}}
Content-Type: {{json}}

{
  "session_id": "{{session_id}}"
}

### 8) Grant user permission
POST {{host}}/iam/grant/user-permission/grant
Authorization: Bearer {{access_token}}
Content-Type: {{json}}

{
  "user_id": 2,
  "permission_id": 1,
  "effect": "ALLOW"
}

### 9) Revoke user permission
POST {{host}}/iam/grant/user-permission/revoke
Authorization: Bearer {{access_token}}
Content-Type: {{json}}

{
  "user_id": 2,
  "permission_id": 1
}

### 10) Logout (requires permission iam:auth:logout)
POST {{host}}/iam/auth/logout
Authorization: Bearer {{access_token}}
Content-Type: {{json}}

{
  "logout_all": false
}

### 11) Register resource
POST {{host}}/iam/resource/register
Authorization: Bearer {{access_token}}
Content-Type: {{json}}

{
  "resource_type": "knowledge.document",
  "resource_name": "Knowledge Document",
  "module_code": "knowledge",
  "status": 1
}

### 12) Register resource action
POST {{host}}/iam/resource/action/register
Authorization: Bearer {{access_token}}
Content-Type: {{json}}

{
  "resource_type": "knowledge.document",
  "action_code": "read",
  "action_name": "Read document",
  "status": 1
}

### 13) Grant ACL
POST {{host}}/iam/acl/grant
Authorization: Bearer {{access_token}}
Content-Type: {{json}}

{
  "subject_type": "USER",
  "subject_id": 2,
  "resource_type": "knowledge.document",
  "resource_id": "doc_001",
  "action_code": "read",
  "effect": "ALLOW"
}

### 14) Authorize check
POST {{host}}/iam/authorize/check
Authorization: Bearer {{access_token}}
Content-Type: {{json}}

{
  "resource_type": "knowledge.document",
  "resource_id": "doc_001",
  "action_code": "read",
  "permission_code": "knowledge:document:read"
}

### 15) Create policy
POST {{host}}/iam/policy/create
Authorization: Bearer {{access_token}}
Content-Type: {{json}}

{
  "policy_code": "knowledge_read_guard",
  "policy_name": "Knowledge read guard",
  "priority": 100,
  "status": 0,
  "version": 1
}

### 16) Add policy rule
POST {{host}}/iam/policy/rule/add
Authorization: Bearer {{access_token}}
Content-Type: {{json}}

{
  "policy_id": 1,
  "subject_type": "USER",
  "subject_id": 2,
  "resource_type": "knowledge.document",
  "resource_id": "doc_001",
  "action_code": "read",
  "effect": "DENY",
  "priority": 100,
  "status": 1
}

### 17) Publish policy
POST {{host}}/iam/policy/publish
Authorization: Bearer {{access_token}}
Content-Type: {{json}}

{
  "policy_id": 1
}

### 18) Decision audit list
POST {{host}}/iam/audit/decision/list
Authorization: Bearer {{access_token}}
Content-Type: {{json}}

{
  "page": 1,
  "page_size": 20
}

