{
  "backend": {
    "secret_key": "change-me-secret-key-at-least-32-chars",
    "jwt_secret_key": "change-me-jwt-secret-key-at-least-32-chars",
    "debug": true,
    "iam_decision_audit_strict_mode": false,
    "allowed_hosts": [
      "127.0.0.1",
      "localhost"
    ],
    "loaded_apps": {
      "iam": true
    },
    "databases": {
      "default": {
        "ENGINE": "django.db.backends.sqlite3",
        "NAME": "db.sqlite3",
        "NS_VENDOR": "sqlite"
      },
      "iam": {
        "ENGINE": "django.db.backends.mysql",
        "NS_VENDOR": "mysql",
        "NAME": "change-me-iam-db-name",
        "USER": "change-me-iam-db-user",
        "PASSWORD": "change-me-iam-db-password",
        "HOST": "change-me-iam-db-host",
        "PORT": "3306",
        "OPTIONS": {
          "charset": "utf8mb4"
        }
      }
    },
    "infra_db_router_map": {
      "iam": "iam"
    },
    "database_router_map": {}
  },
  "cache_config": {
    "backend": "sql_wal",
    "location": "ns_cache.sqlite3",
    "key_prefix": "ns",
    "default_timeout_seconds": 300,
    "serializer": "pickle",
    "sql_table": "ns_cache",
    "sql_timeout_seconds": 5.0,
    "sql_max_entries": 10000,
    "sql_cull_frequency": 3,
    "socket_timeout": 3.0,
    "socket_connect_timeout": 3.0,
    "max_connections": 64,
    "health_check_interval": 30
  },
  "log_config": {
    "level": "INFO",
    "file_level": "INFO",
    "console_level": "INFO",
    "console": true,
    "format_type": "json",
    "console_format_type": "text",
    "file_format_type": "json",
    "datefmt": "%Y-%m-%d %H:%M:%S",
    "when": "midnight",
    "interval": 1,
    "backup_count": 30,
    "encoding": "utf-8",
    "delay": true,
    "utc": false,
    "at_time": null,
    "max_bytes": 0,
    "use_gzip": false,
    "lock_file_directory": null,
    "level_files": [
      "INFO",
      "WARNING",
      "ERROR",
      "CRITICAL"
    ]
  },
  "object_storage_config": {
    "backend": "local_fs",
    "default_bucket": "ns-local",
    "auto_create_bucket": true,
    "key_prefix": "ns",
    "local_root_path": "object_storage",
    "max_object_size": null
  }
}

